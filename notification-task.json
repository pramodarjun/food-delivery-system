{
  "family": "notification-service",
  "networkMode": "bridge",
  "requiresCompatibilities": ["EC2"],
  "containerDefinitions": [
    {
      "name": "notification-service",
      "image": "397562347081.dkr.ecr.us-east-1.amazonaws.com/notification-service:latest",
      "memory": 512,
      "cpu": 256,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8082,
          "hostPort": 8082,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SPRING_KAFKA_BOOTSTRAP_SERVERS", "value": "kafka:9092" }
      ]
    }
  ]
}
